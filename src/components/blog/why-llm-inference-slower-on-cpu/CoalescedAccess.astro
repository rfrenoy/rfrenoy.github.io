---
/**
 * Interactive coalesced vs uncoalesced memory access.
 * Toggle between the two patterns to see the difference.
 */
---

<figure class="coalesced-access">
  <div class="toggle-bar">
    <button class="toggle-btn active" data-mode="coalesced">✅ Coalesced</button>
    <button class="toggle-btn" data-mode="uncoalesced">❌ Uncoalesced</button>
  </div>

  <!-- Coalesced view -->
  <div class="view coalesced-view active">
    <svg viewBox="0 0 600 200" xmlns="http://www.w3.org/2000/svg">
      <text x="300" y="16" class="section-title">32 threads in a warp, each reading one float</text>

      <!-- Threads -->
      <text x="300" y="36" class="row-label">Threads</text>
      {Array.from({ length: 32 }).map((_, i) => (
        <rect x={12 + i * 18} y="42" width="16" height="16" rx="2" class="thread"
              style={`animation-delay: ${i * 0.02}s`} />
      ))}

      <!-- Arrows (all point to contiguous block) -->
      {Array.from({ length: 32 }).map((_, i) => (
        <line x1={20 + i * 18} y1="58" x2={20 + i * 18} y2="90" class="arrow-good" />
      ))}

      <!-- Memory: one contiguous 128-byte block -->
      <text x="300" y="103" class="row-label">VRAM (global memory)</text>
      <rect x="10" y="108" width={32 * 18} height="22" rx="4" class="mem-block good" />
      <text x="300" y="123" class="mem-label">128 bytes — 1 transaction</text>

      <!-- Result -->
      <text x="300" y="160" class="result good-text">1 memory transaction serves all 32 threads</text>
      <text x="300" y="178" class="result good-text">Full bandwidth utilization ✅</text>
    </svg>
  </div>

  <!-- Uncoalesced view -->
  <div class="view uncoalesced-view">
    <svg viewBox="0 0 600 210" xmlns="http://www.w3.org/2000/svg">
      <text x="300" y="16" class="section-title">32 threads, each reading with stride 32</text>

      <!-- Threads -->
      <text x="300" y="36" class="row-label">Threads</text>
      {Array.from({ length: 32 }).map((_, i) => (
        <rect x={12 + i * 18} y="42" width="16" height="16" rx="2" class="thread" />
      ))}

      <!-- Arrows (scattered — showing a few representative arrows to different segments) -->
      {Array.from({ length: 8 }).map((_, i) => (
        <line x1={20 + i * 72} y1="58" x2={20 + i * 72} y2="90" class="arrow-bad" />
      ))}
      {Array.from({ length: 8 }).map((_, i) => (
        <line x1={20 + (i * 4 + 1) * 18} y1="58"
              x2={20 + i * 72 + 10} y2="90" class="arrow-bad scattered" />
      ))}

      <!-- Memory: scattered blocks -->
      <text x="300" y="103" class="row-label">VRAM (global memory)</text>
      {Array.from({ length: 8 }).map((_, i) => (
        <rect x={10 + i * 72} y="108" width="20" height="22" rx="3" class="mem-block bad" />
      ))}
      {Array.from({ length: 8 }).map((_, i) => (
        <rect x={36 + i * 72} y="108" width="40" height="22" rx="3" class="mem-block wasted" />
      ))}
      <text x="300" y="123" class="mem-label">scattered — up to 32 transactions</text>

      <!-- Simplified note -->
      <text x="300" y="148" class="simplified-note">(showing 8 of 32 segments for clarity)</text>

      <!-- Result -->
      <text x="300" y="172" class="result bad-text">Up to 32 separate memory transactions</text>
      <text x="300" y="190" class="result bad-text">Bandwidth wasted on unused bytes ❌</text>
    </svg>
  </div>
  <figcaption>Click to toggle. Coalesced access: adjacent threads read adjacent addresses → 1 wide transaction. Uncoalesced: threads read scattered addresses → many serialized transactions.</figcaption>
</figure>

<script>
  document.querySelectorAll('.coalesced-access .toggle-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const parent = btn.closest('.coalesced-access');
      parent.querySelectorAll('.toggle-btn').forEach(b => b.classList.remove('active'));
      parent.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
      btn.classList.add('active');
      const mode = btn.getAttribute('data-mode');
      parent.querySelector(`.${mode}-view`).classList.add('active');
    });
  });
</script>

<style>
  .coalesced-access {
    margin: 1.5rem 0;
  }
  .coalesced-access figcaption {
    text-align: center;
    font-size: 0.82rem;
    color: #888;
    margin-top: 0.5rem;
  }
  .toggle-bar {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .toggle-btn {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.8rem;
    padding: 0.35rem 1rem;
    border: 1.5px solid #ccc;
    border-radius: 6px;
    background: #fafafa;
    cursor: pointer;
    transition: all 0.15s;
  }
  .toggle-btn.active {
    background: #eef4ff;
    border-color: #7da4d9;
    font-weight: 600;
  }
  .toggle-btn:hover {
    background: #f0f0f0;
  }
  .view {
    display: none;
  }
  .view.active {
    display: block;
  }
  .view svg {
    width: 100%;
    max-width: 600px;
    display: block;
    margin: 0 auto;
  }
  .section-title {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 9px;
    text-anchor: middle;
    fill: #888;
  }
  .row-label {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 8px;
    text-anchor: middle;
    fill: #aaa;
    font-weight: 600;
  }
  .thread {
    fill: #7da4d9;
    stroke: #5a8abf;
    stroke-width: 1;
  }
  .arrow-good {
    stroke: #4caf50;
    stroke-width: 1;
    opacity: 0.6;
  }
  .arrow-bad {
    stroke: #e57373;
    stroke-width: 1;
    opacity: 0.5;
  }
  .arrow-bad.scattered {
    stroke-dasharray: 3 2;
  }
  .mem-block {
    stroke-width: 1.5;
  }
  .mem-block.good {
    fill: #c8e6c9;
    stroke: #4caf50;
  }
  .mem-block.bad {
    fill: #ffcdd2;
    stroke: #e57373;
  }
  .mem-block.wasted {
    fill: #f5f5f5;
    stroke: #ddd;
    stroke-dasharray: 3 2;
  }
  .mem-label {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 8px;
    text-anchor: middle;
    fill: #888;
  }
  .result {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 10px;
    text-anchor: middle;
    font-weight: 600;
  }
  .good-text { fill: #2e7d32; }
  .bad-text { fill: #c62828; }
  .simplified-note {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 7.5px;
    text-anchor: middle;
    fill: #bbb;
    font-style: italic;
  }
</style>

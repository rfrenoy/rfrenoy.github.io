---
/**
 * LLM inference comparison: CPU vs GPU.
 * Shows weights streaming through narrow (RAM) vs wide (VRAM) bus,
 * with a token generation speed counter.
 */
---

<figure class="llm-inference">
  <div class="llm-grid">
    <!-- CPU side -->
    <div class="llm-col">
      <div class="llm-title">CPU inference (Apple M2, LPDDR5)</div>
      <svg viewBox="0 0 280 320" xmlns="http://www.w3.org/2000/svg">
        <!-- Model weights in RAM -->
        <rect x="40" y="10" width="200" height="44" rx="6" class="weights ram-weights" />
        <text x="140" y="30" class="weight-label">Model weights (14 GB)</text>
        <text x="140" y="42" class="weight-sub">in RAM</text>

        <!-- Narrow bus -->
        <rect x="120" y="60" width="40" height="80" rx="4" class="bus narrow-bus" />
        <text x="140" y="92" class="bus-label narrow-text">128-bit</text>
        <text x="140" y="104" class="bus-bw narrow-text">~100 GB/s</text>

        <!-- Animated data trickle -->
        <rect x="130" y="62" width="20" height="8" rx="2" class="data-chunk narrow-chunk chunk-1" />
        <rect x="130" y="62" width="20" height="8" rx="2" class="data-chunk narrow-chunk chunk-2" />
        <rect x="130" y="62" width="20" height="8" rx="2" class="data-chunk narrow-chunk chunk-3" />

        <!-- CPU cores -->
        <rect x="70" y="150" width="140" height="44" rx="6" class="compute cpu-compute" />
        <text x="140" y="169" class="compute-label">CPU (16 cores)</text>
        <text x="140" y="182" class="compute-sub">Matrix-vector multiply</text>

        <!-- Output token -->
        <line x1="140" y1="194" x2="140" y2="218" class="output-wire" />
        <rect x="100" y="220" width="80" height="28" rx="6" class="token-box cpu-token" />
        <text x="140" y="238" class="token-label">token</text>

        <!-- Speed -->
        <text x="140" y="272" class="speed cpu-speed">~140 ms / token</text>
        <text x="140" y="290" class="speed-big cpu-speed">~7 tokens/sec</text>

        <!-- Bottleneck callout -->
        <rect x="175" y="72" width="95" height="22" rx="4" class="bottleneck-box" />
        <text x="222" y="87" class="bottleneck-text">⚠ bottleneck</text>
        <line x1="175" y1="83" x2="162" y2="90" class="bottleneck-line" />
      </svg>
    </div>

    <!-- GPU side -->
    <div class="llm-col">
      <div class="llm-title">GPU inference (GDDR6X)</div>
      <svg viewBox="0 0 280 320" xmlns="http://www.w3.org/2000/svg">
        <!-- Model weights in VRAM -->
        <rect x="40" y="10" width="200" height="44" rx="6" class="weights vram-weights" />
        <text x="140" y="30" class="weight-label">Model weights (14 GB)</text>
        <text x="140" y="42" class="weight-sub">in VRAM</text>

        <!-- Wide bus -->
        <rect x="50" y="60" width="180" height="80" rx="4" class="bus wide-bus" />
        <text x="140" y="92" class="bus-label wide-text">384-bit</text>
        <text x="140" y="104" class="bus-bw wide-text">~1,000 GB/s</text>

        <!-- Animated data flood -->
        {Array.from({ length: 6 }).map((_, i) => (
          <rect x={60 + i * 26} y="62" width="22" height="8" rx="2"
                class={`data-chunk wide-chunk chunk-${(i % 3) + 1}`} />
        ))}

        <!-- GPU cores -->
        <rect x="30" y="150" width="220" height="44" rx="6" class="compute gpu-compute" />
        <text x="140" y="169" class="compute-label">GPU (thousands of cores)</text>
        <text x="140" y="182" class="compute-sub">Massively parallel matmul</text>

        <!-- Output token -->
        <line x1="140" y1="194" x2="140" y2="218" class="output-wire" />
        <rect x="100" y="220" width="80" height="28" rx="6" class="token-box gpu-token" />
        <text x="140" y="238" class="token-label">token</text>

        <!-- Speed -->
        <text x="140" y="272" class="speed gpu-speed">~14 ms / token</text>
        <text x="140" y="290" class="speed-big gpu-speed">~70 tokens/sec</text>

        <!-- 10× callout -->
        <rect x="168" y="148" width="88" height="22" rx="4" class="speedup-box" />
        <text x="212" y="163" class="speedup-text">10× faster</text>
      </svg>
    </div>
  </div>

  <!-- Token generation race -->
  <div class="token-race">
    <div class="race-title">Token generation over 1 second</div>
    <div class="race-row">
      <span class="race-label">CPU</span>
      <div class="race-bar">
        {Array.from({ length: 7 }).map((_, i) => (
          <span class="race-token cpu-race-token" style={`animation-delay: ${i * 0.14}s`}>▍</span>
        ))}
      </div>
      <span class="race-count">~7 tokens</span>
    </div>
    <div class="race-row">
      <span class="race-label">GPU</span>
      <div class="race-bar">
        {Array.from({ length: 20 }).map((_, i) => (
          <span class="race-token gpu-race-token" style={`animation-delay: ${i * 0.05}s`}>▍</span>
        ))}
      </div>
      <span class="race-count">~70 tokens</span>
    </div>
  </div>

  <figcaption>LLM inference is memory-bandwidth-bound: every token requires streaming the full model weights. The GPU's <mark>~10× higher bandwidth</mark> translates almost directly to ~10× faster generation (up to ~20× vs x86 DDR5).</figcaption>
</figure>

<style>
  .llm-inference {
    margin: 1.5rem 0;
  }
  .llm-inference figcaption {
    text-align: center;
    font-size: 0.82rem;
    color: #888;
    margin-top: 0.75rem;
  }
  .llm-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 600px) {
    .llm-grid { grid-template-columns: 1fr; }
  }
  .llm-col svg {
    width: 100%;
    display: block;
  }
  .llm-title {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.85rem;
    font-weight: 600;
    text-align: center;
    margin-bottom: 0.3rem;
    color: #333;
  }

  /* Weights */
  .weights { stroke-width: 1.5; }
  .ram-weights { fill: #dbe7fa; stroke: #7da4d9; }
  .vram-weights { fill: #d9f0c8; stroke: #6ea84a; }
  .weight-label {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 10px;
    font-weight: 600;
    text-anchor: middle;
    fill: #333;
  }
  .weight-sub {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 8px;
    text-anchor: middle;
    fill: #888;
  }

  /* Bus */
  .bus { stroke-width: 1.5; }
  .narrow-bus { fill: #fff3e0; stroke: #e6a23c; }
  .wide-bus { fill: #e8f5e9; stroke: #66bb6a; }
  .bus-label {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 11px;
    font-weight: 700;
    text-anchor: middle;
  }
  .bus-bw {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 9px;
    font-weight: 600;
    text-anchor: middle;
  }
  .narrow-text { fill: #b37400; }
  .wide-text { fill: #2e7d32; }

  /* Data chunks animation */
  .data-chunk {
    opacity: 0;
  }
  .narrow-chunk { fill: #e6a23c; }
  .wide-chunk { fill: #66bb6a; }
  .chunk-1 { animation: stream-down 1.2s ease-in-out 0.2s infinite; }
  .chunk-2 { animation: stream-down 1.2s ease-in-out 0.6s infinite; }
  .chunk-3 { animation: stream-down 1.2s ease-in-out 1.0s infinite; }

  @keyframes stream-down {
    0% { opacity: 0; transform: translateY(0); }
    20% { opacity: 0.8; }
    80% { opacity: 0.8; }
    100% { opacity: 0; transform: translateY(64px); }
  }

  /* Compute */
  .compute { stroke-width: 1.5; }
  .cpu-compute { fill: #eef4ff; stroke: #9bb8e8; }
  .gpu-compute { fill: #e8f5e9; stroke: #81c784; }
  .compute-label {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 10px;
    font-weight: 600;
    text-anchor: middle;
    fill: #333;
  }
  .compute-sub {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 8px;
    text-anchor: middle;
    fill: #888;
  }

  /* Token output */
  .output-wire { stroke: #bbb; stroke-width: 1.5; }
  .token-box { stroke-width: 1.5; }
  .cpu-token { fill: #f0f0f0; stroke: #aaa; }
  .gpu-token { fill: #e8f5e9; stroke: #66bb6a; }
  .token-label {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 10px;
    font-weight: 600;
    text-anchor: middle;
    fill: #555;
  }

  /* Speed labels */
  .speed {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 10px;
    text-anchor: middle;
    font-weight: 600;
  }
  .speed-big {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 14px;
    text-anchor: middle;
    font-weight: 700;
  }
  .cpu-speed { fill: #b37400; }
  .gpu-speed { fill: #2e7d32; }

  /* Callouts */
  .bottleneck-box { fill: #fff3e0; stroke: #e6a23c; stroke-width: 1; }
  .bottleneck-text {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 8px;
    text-anchor: middle;
    fill: #b37400;
    font-weight: 600;
  }
  .bottleneck-line { stroke: #e6a23c; stroke-width: 1; }
  .speedup-box { fill: #e8f5e9; stroke: #4caf50; stroke-width: 1.5; }
  .speedup-text {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 10px;
    text-anchor: middle;
    fill: #2e7d32;
    font-weight: 700;
  }

  /* Token race */
  .token-race {
    margin-top: 1rem;
    padding: 0.75rem 1rem;
    background: #fafafa;
    border: 1px solid #eee;
    border-radius: 8px;
  }
  .race-title {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.78rem;
    font-weight: 600;
    text-align: center;
    color: #555;
    margin-bottom: 0.5rem;
  }
  .race-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.3rem;
  }
  .race-label {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.78rem;
    font-weight: 600;
    width: 2.5rem;
    color: #555;
  }
  .race-bar {
    flex: 1;
    display: flex;
    gap: 2px;
    min-height: 1.4rem;
    align-items: center;
  }
  .race-token {
    opacity: 0;
    font-size: 1rem;
    line-height: 1;
    animation: token-appear 0.15s ease-out forwards;
  }
  .cpu-race-token { color: #e6a23c; }
  .gpu-race-token { color: #4caf50; }
  .race-count {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: #888;
    width: 5.5rem;
    text-align: right;
  }
  @keyframes token-appear {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

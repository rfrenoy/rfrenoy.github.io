---
interface Props {
  title: string;
  currentPath?: string;
}

const { title, currentPath } = Astro.props;

const nav = [
  { name: "Home", link: "/" },
  { name: "About me", link: "/about/" },
  { name: "CV", link: "/cv/" },
  { name: "Blog", link: "/blog/" },
  { name: "Daily Feed", link: "/daily-feed/" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Rémy Frenoy"
      href="/rss.xml"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css"
    />
  </head>

  <body>
    <div class="container">
      <div class="sidebar">
        <header>
          <h1><a href="/">Rémy Frenoy</a></h1>
          <p class="tagline">Machine Learning / Software Engineer</p>
          <div class="social-links">
            <a href="https://github.com/rfrenoy" aria-label="GitHub" title="GitHub">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            </a>
            <a href="https://www.linkedin.com/in/rfrenoy/" aria-label="LinkedIn" title="LinkedIn">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href="/rss.xml" aria-label="RSS Feed" title="RSS Feed">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M19.199 24C19.199 13.467 10.533 4.8 0 4.8V0c13.165 0 24 10.835 24 24h-4.801zM3.291 17.415a3.3 3.3 0 013.293 3.295A3.303 3.303 0 013.283 24C1.47 24 0 22.526 0 20.71a3.286 3.286 0 013.291-3.295zM15.909 24h-4.665c0-6.169-5.075-11.245-11.244-11.245V8.09c8.727 0 15.909 7.184 15.909 15.91z"/></svg>
            </a>
          </div>
        </header>
        <nav>
          <ul>
            {
              nav.map((item) => (
                <li>
                  <a
                    href={item.link}
                    class={currentPath === item.link ? "current" : ""}
                  >
                    {item.name}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
      <main>
        <slot />
      </main>
    </div>
    <footer>&copy; Rémy Frenoy — {new Date().getFullYear()}</footer>
  </body>
</html>

<style is:global>
  /* Reset */
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  /* Base */
  html,
  body {
    height: 100%;
  }

  body {
    font-family: "Palatino", "Georgia", "Times New Roman", serif;
    display: flex;
    flex-direction: column;
    line-height: 1.6;
    color: #1a1a1a;
  }

  a {
    color: rgb(139, 48, 32);
  }

  h1 {
    font-size: 1.4rem;
    font-weight: bold;
  }

  h2 {
    font-size: 1.3rem;
    font-weight: bold;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  h3 {
    font-size: 1.1rem;
    font-weight: bold;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  p {
    margin-bottom: 1rem;
  }

  strong {
    font-weight: bold;
  }

  em {
    font-style: italic;
  }

  mark {
    background: rgb(219, 222, 255);
    padding: 0.05em 0.2em;
    border-radius: 2px;
  }

  ul {
    list-style: disc inside;
  }

  li {
    margin-bottom: 0.25rem;
  }

  /* CV-specific: top-level items have no bullet, nested lists have bullets */
  .cv > ul {
    list-style: none;
  }

  .cv > ul > li {
    margin-top: 1.5rem;
  }

  .cv > ul > li:first-child {
    margin-top: 0;
  }

  .cv > ul > li > p {
    margin-bottom: 0.15rem;
  }

  .cv > ul > li > ul {
    list-style: disc inside;
    margin-left: 1rem;
    margin-top: 0.3rem;
  }

  .cv > ul > li > ul > li > ul {
    list-style: disc inside;
    margin-left: 1.5rem;
  }

  /* Layout */
  .container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    margin: 2% 10% 2% 10%;
    flex-grow: 1;
  }

  .sidebar {
    padding: 2%;
    flex: 1;
    min-width: 200px;
  }

  .sidebar h1 a {
    text-decoration: none;
    color: inherit;
  }

  .sidebar .tagline {
    color: #555;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .social-links {
    display: flex;
    gap: 0.6rem;
    margin-bottom: 0.25rem;
  }

  .social-links a {
    color: #555;
    transition: color 0.15s;
  }

  .social-links a:hover {
    color: rgb(139, 48, 32);
  }

  .sidebar nav ul {
    list-style: none;
    margin-top: 1.5rem;
  }

  .sidebar nav a {
    text-decoration: none;
  }

  .sidebar nav a.current {
    font-weight: bold;
  }

  main {
    padding: 2% 5%;
    flex: 3;
    min-width: 0;
    max-width: 800px;
  }

  footer {
    margin-top: auto;
    text-align: center;
    padding: 1rem;
    color: #888;
    font-size: 0.85rem;
  }

  /* Code blocks */
  pre {
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  code {
    font-family: "SF Mono", "Fira Code", "Fira Mono", Menlo, monospace;
    font-size: 0.88em;
  }

  :not(pre) > code {
    background: #f0f0f0;
    padding: 0.15em 0.35em;
    border-radius: 3px;
  }

  /* Code comparison component */
  .code-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .code-compare > div {
    min-width: 0;
    overflow: hidden;
  }

  .code-compare .code-title {
    font-family: "SF Mono", "Fira Code", monospace;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.4rem 0.75rem;
    background: #e8e8e8;
    border-radius: 6px 6px 0 0;
    color: #444;
  }

  .code-compare pre {
    border-radius: 0 0 6px 6px;
    margin-bottom: 0;
  }

  /* Highlighted lines in code blocks */
  .code-compare pre .highlight-line {
    background: rgba(255, 220, 100, 0.25);
    display: block;
    margin: 0 -1rem;
    padding: 0 1rem;
  }

  @media (max-width: 768px) {
    .container {
      margin: 1rem;
      flex-direction: column;
    }

    .code-compare {
      grid-template-columns: 1fr;
    }
  }

  /* Blog post list */
  .post-list {
    list-style: none;
  }

  .post-list li {
    margin-bottom: 1.5rem;
  }

  .post-list .post-date {
    color: #888;
    font-size: 0.85rem;
  }

  .post-list .post-description {
    color: #555;
    font-size: 0.9rem;
  }

  /* Blog post */
  .post-header {
    margin-bottom: 2rem;
    border-bottom: 1px solid #ddd;
    padding-bottom: 1rem;
  }

  .post-header h1 {
    font-size: 1.6rem;
    margin-bottom: 0.5rem;
  }

  .post-header .post-meta {
    color: #888;
    font-size: 0.9rem;
  }

  /* Callout boxes */
  .callout {
    padding: 1rem 1.25rem;
    border-left: 4px solid #4a9eff;
    background: #f0f7ff;
    border-radius: 0 6px 6px 0;
    margin-bottom: 1.5rem;
  }

  .callout p:last-child {
    margin-bottom: 0;
  }

  .callout.warning {
    border-left-color: #f0a020;
    background: #fff8ee;
  }

  /* KaTeX display math */
  .katex-display {
    margin: 1.5rem 0;
    overflow-x: auto;
  }

  /* Section spacing in CV / about */
  section {
    margin-bottom: 2rem;
  }

  section ul ul {
    margin-left: 1.5rem;
  }
</style>
